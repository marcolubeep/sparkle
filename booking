<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sparkle MK — Book a Clean</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --green: #3a9e7e;
  --green-light: #e8f7f2;
  --green-dark: #1f6b53;
  --green-mid: #2d8566;
  --sky: #d4eef8;
  --text: #1a2e25;
  --muted: #6b8f7e;
  --white: #ffffff;
  --bg: #f5fbf8;
  --border: rgba(58,158,126,0.18);
  --shadow: 0 2px 20px rgba(58,158,126,0.10);
  --error: #c0392b;
  --error-bg: #fdf0ef;
  --success: #1f6b53;
  --success-bg: #e8f7f2;
}
html { scroll-behavior: smooth; }
body { font-family: 'Nunito', sans-serif; font-weight: 400; color: var(--text); background: var(--bg); overflow-x: hidden; }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 2rem;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-logo { display: flex; align-items: center; gap: 10px; text-decoration: none; }
.nav-logo svg { width: 36px; height: 36px; }
.nav-logo span { font-weight: 800; font-size: 1.15rem; color: var(--text); }
.nav-logo span em { font-style: normal; color: var(--green); }
.nav-links { display: flex; gap: 1.5rem; align-items: center; }
.nav-links a { text-decoration: none; color: var(--muted); font-weight: 600; font-size: 0.9rem; transition: color 0.2s; }
.nav-links a:hover, .nav-links a.active { color: var(--green); }
.nav-admin-btn {
  background: var(--text); color: white; text-decoration: none;
  padding: 8px 18px; border-radius: 50px; font-weight: 700; font-size: 0.85rem;
  cursor: pointer; border: none; transition: background 0.2s;
}
.nav-admin-btn:hover { background: var(--green-dark); }

/* ── PAGE SECTIONS ── */
.page { display: none; padding-top: 80px; min-height: 100vh; }
.page.active { display: block; }

/* ── BOOKING PAGE HERO ── */
.booking-hero {
  background: linear-gradient(135deg, #d4eef8 0%, #e8f7f2 50%, #c8edd8 100%);
  padding: 3.5rem 1.5rem 2.5rem;
  text-align: center;
}
.booking-hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 5vw, 2.6rem); color: var(--text); margin-bottom: 0.5rem; }
.booking-hero h1 span { color: var(--green); }
.booking-hero p { color: var(--muted); font-size: 1rem; max-width: 400px; margin: 0 auto; line-height: 1.6; }

/* ── BOOKING FORM ── */
.booking-wrapper { max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

.step-indicator {
  display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 2.5rem;
}
.step { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; }
.step-circle {
  width: 32px; height: 32px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 700;
  background: white; border: 2px solid var(--border); color: var(--muted);
  transition: all 0.3s;
}
.step.active .step-circle { background: var(--green); border-color: var(--green); color: white; }
.step.done .step-circle { background: var(--green-light); border-color: var(--green); color: var(--green-dark); }
.step-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
.step.active .step-label { color: var(--green-dark); }
.step-line { flex: 1; height: 2px; background: var(--border); margin: 0; position: relative; top: -10px; }
.step-line.done { background: var(--green); }

/* FORM CARDS */
.form-card {
  background: white; border-radius: 20px; padding: 2rem;
  border: 1px solid var(--border); box-shadow: var(--shadow);
  margin-bottom: 1.5rem; display: none;
}
.form-card.active { display: block; animation: fadeUp 0.3s ease both; }
@keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }

.form-card h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 1.5rem; color: var(--text); }

/* SERVICE SELECTOR */
.service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
.service-option { position: relative; }
.service-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
.service-option label {
  display: flex; flex-direction: column; align-items: flex-start;
  gap: 6px; padding: 1.1rem 1rem;
  border: 1.5px solid var(--border); border-radius: 14px;
  cursor: pointer; transition: all 0.2s; background: white;
}
.service-option label:hover { border-color: var(--green); background: var(--green-light); }
.service-option input:checked + label { border-color: var(--green); background: var(--green-light); }
.service-option input:checked + label .service-check { opacity: 1; }
.svc-icon { font-size: 1.4rem; }
.svc-name { font-weight: 700; font-size: 0.95rem; color: var(--text); }
.svc-price { font-size: 0.82rem; color: var(--green-dark); font-weight: 600; }
.svc-desc { font-size: 0.78rem; color: var(--muted); line-height: 1.4; }
.service-check { position: absolute; top: 10px; right: 10px; width: 18px; height: 18px; border-radius: 50%; background: var(--green); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
.service-check::after { content: ''; display: block; width: 5px; height: 9px; border: 2px solid white; border-top: none; border-left: none; transform: rotate(45deg) translateY(-1px); }

/* FREQUENCY */
.freq-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
.freq-option { position: relative; }
.freq-option input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
.freq-option label {
  display: block; padding: 0.8rem 0.5rem; text-align: center;
  border: 1.5px solid var(--border); border-radius: 10px;
  cursor: pointer; transition: all 0.2s; font-weight: 700; font-size: 0.88rem;
}
.freq-option input:checked + label { border-color: var(--green); background: var(--green-light); color: var(--green-dark); }
.freq-option label:hover { border-color: var(--green); }
.freq-discount { display: block; font-size: 11px; font-weight: 600; color: var(--green); margin-top: 2px; }

/* FORM FIELDS */
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
.form-row.full { grid-template-columns: 1fr; }
.form-group { display: flex; flex-direction: column; gap: 5px; }
.form-group label { font-size: 13px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
.form-group input,
.form-group select,
.form-group textarea {
  border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 14px;
  font-family: 'Nunito', sans-serif; font-size: 0.95rem; color: var(--text);
  background: white; outline: none; transition: border-color 0.2s;
  width: 100%;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--green); }
.form-group textarea { resize: vertical; min-height: 80px; }
.form-group.error input,
.form-group.error select { border-color: var(--error); }
.field-error { font-size: 12px; color: var(--error); margin-top: 2px; display: none; }
.form-group.error .field-error { display: block; }

/* TIME SLOTS */
.time-slots { display: grid; grid-template-columns: repeat(4,1fr); gap: 0.6rem; margin-top: 0.5rem; }
.time-slot { position: relative; }
.time-slot input[type="radio"] { position: absolute; opacity: 0; width: 0; height: 0; }
.time-slot label {
  display: block; text-align: center; padding: 8px 4px;
  border: 1.5px solid var(--border); border-radius: 8px;
  cursor: pointer; font-size: 0.82rem; font-weight: 700; transition: all 0.2s;
}
.time-slot input:checked + label { border-color: var(--green); background: var(--green-light); color: var(--green-dark); }
.time-slot label:hover { border-color: var(--green); }
.time-slot label.unavailable { opacity: 0.4; cursor: not-allowed; background: #f5f5f5; }

/* SUMMARY CARD */
.summary-box {
  background: var(--green-light); border-radius: 14px;
  padding: 1.25rem 1.5rem; margin-bottom: 1.5rem;
  border: 1px solid rgba(58,158,126,0.2);
}
.summary-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; font-size: 0.92rem; }
.summary-row.total { border-top: 1.5px solid rgba(58,158,126,0.25); padding-top: 10px; margin-top: 5px; font-weight: 800; font-size: 1.05rem; color: var(--green-dark); }
.summary-label { color: var(--muted); }
.summary-value { font-weight: 700; color: var(--text); }

/* PAYMENT SECTION */
.payment-area {
  background: white; border: 1.5px solid var(--border); border-radius: 14px;
  padding: 1.25rem; margin-bottom: 1.5rem;
}
.payment-title { font-weight: 800; font-size: 0.95rem; color: var(--text); margin-bottom: 1rem; display: flex; align-items: center; gap: 8px; }
.stripe-badge { display: inline-flex; align-items: center; gap: 5px; background: #f0f4ff; border-radius: 6px; padding: 3px 8px; font-size: 11px; color: #6772e5; font-weight: 700; }
.card-field-mock {
  border: 1.5px solid var(--border); border-radius: 10px; padding: 11px 14px;
  font-size: 0.9rem; color: var(--muted); margin-bottom: 0.75rem;
  display: flex; align-items: center; gap: 8px; cursor: text;
  transition: border-color 0.2s;
}
.card-field-mock:focus-within { border-color: var(--green); }
.card-field-mock input { border: none; outline: none; flex: 1; font-family: 'Nunito', sans-serif; font-size: 0.9rem; color: var(--text); background: transparent; }
.card-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.secure-note { font-size: 11.5px; color: var(--muted); text-align: center; margin-top: 0.75rem; }
.secure-note strong { color: var(--text); }

/* BUTTONS */
.btn-primary {
  width: 100%; padding: 14px 20px; border-radius: 50px;
  background: var(--green); color: white; border: none;
  font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 1rem;
  cursor: pointer; transition: background 0.2s, transform 0.15s;
  box-shadow: 0 4px 18px rgba(58,158,126,0.3);
}
.btn-primary:hover { background: var(--green-dark); transform: translateY(-1px); }
.btn-primary:active { transform: translateY(0); }
.btn-primary:disabled { background: var(--muted); box-shadow: none; cursor: not-allowed; transform: none; }
.btn-secondary {
  width: 100%; padding: 12px 20px; border-radius: 50px;
  background: white; color: var(--green); border: 2px solid var(--green);
  font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 0.95rem;
  cursor: pointer; transition: all 0.2s; margin-bottom: 0.75rem;
}
.btn-secondary:hover { background: var(--green-light); }
.btn-back { background: none; border: none; color: var(--muted); font-family: 'Nunito', sans-serif; font-weight: 600; font-size: 0.9rem; cursor: pointer; padding: 0; margin-bottom: 1rem; display: inline-flex; align-items: center; gap: 5px; }
.btn-back:hover { color: var(--green); }

/* SUCCESS STATE */
.success-card {
  background: white; border-radius: 20px; padding: 3rem 2rem;
  text-align: center; border: 1px solid var(--border); box-shadow: var(--shadow);
}
.success-icon {
  width: 72px; height: 72px; border-radius: 50%;
  background: var(--green-light); display: flex; align-items: center; justify-content: center;
  margin: 0 auto 1.5rem; font-size: 2rem;
}
.success-card h2 { font-family: 'Playfair Display', serif; font-size: 1.8rem; margin-bottom: 0.75rem; }
.success-card p { color: var(--muted); line-height: 1.65; max-width: 360px; margin: 0 auto 0.5rem; }
.booking-ref { display: inline-block; background: var(--green-light); color: var(--green-dark); font-weight: 800; padding: 8px 20px; border-radius: 50px; font-size: 0.95rem; margin: 1rem 0; letter-spacing: 0.05em; }

/* ── ADMIN PAGE ── */
.admin-login-wrapper { max-width: 400px; margin: 4rem auto; padding: 0 1.5rem; }
.admin-login-card { background: white; border-radius: 20px; padding: 2.5rem; border: 1px solid var(--border); box-shadow: var(--shadow); text-align: center; }
.admin-login-card h2 { font-family: 'Playfair Display', serif; font-size: 1.6rem; margin-bottom: 0.5rem; }
.admin-login-card p { color: var(--muted); font-size: 0.9rem; margin-bottom: 2rem; }
.login-error { background: var(--error-bg); color: var(--error); padding: 10px 14px; border-radius: 8px; font-size: 0.88rem; font-weight: 600; margin-bottom: 1rem; display: none; }

.admin-dashboard { max-width: 1000px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
.admin-header h1 { font-family: 'Playfair Display', serif; font-size: 1.8rem; }
.admin-header-right { display: flex; gap: 0.75rem; align-items: center; }

.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
.stat-card {
  background: white; border-radius: 14px; padding: 1.25rem;
  border: 1px solid var(--border); text-align: center;
}
.stat-num { font-family: 'Playfair Display', serif; font-size: 2rem; color: var(--green); font-weight: 700; }
.stat-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-top: 2px; }

.filter-bar { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.filter-btn {
  padding: 7px 16px; border-radius: 50px; font-family: 'Nunito', sans-serif;
  font-size: 0.82rem; font-weight: 700; cursor: pointer; border: 1.5px solid var(--border);
  background: white; color: var(--muted); transition: all 0.2s;
}
.filter-btn:hover, .filter-btn.active { background: var(--green); border-color: var(--green); color: white; }

.bookings-table-wrap { background: white; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; }
.bookings-table { width: 100%; border-collapse: collapse; }
.bookings-table th { background: var(--green-light); color: var(--green-dark); font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; padding: 12px 16px; text-align: left; }
.bookings-table td { padding: 13px 16px; border-top: 1px solid rgba(58,158,126,0.1); font-size: 0.9rem; vertical-align: middle; }
.bookings-table tr:hover td { background: var(--bg); }

.badge {
  display: inline-block; padding: 3px 10px; border-radius: 50px;
  font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em;
}
.badge-pending { background: #fff8e6; color: #b8860b; }
.badge-confirmed { background: var(--green-light); color: var(--green-dark); }
.badge-paid { background: #e6f4ff; color: #1a5fa0; }
.badge-cancelled { background: #fdf0ef; color: var(--error); }

.action-btns { display: flex; gap: 6px; }
.action-btn {
  padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 700;
  cursor: pointer; border: 1.5px solid; font-family: 'Nunito', sans-serif;
  transition: all 0.2s;
}
.action-btn.confirm { border-color: var(--green); color: var(--green); background: white; }
.action-btn.confirm:hover { background: var(--green); color: white; }
.action-btn.cancel { border-color: var(--error); color: var(--error); background: white; }
.action-btn.cancel:hover { background: var(--error); color: white; }
.action-btn.paid { border-color: #1a5fa0; color: #1a5fa0; background: white; }
.action-btn.paid:hover { background: #1a5fa0; color: white; }

.empty-state { text-align: center; padding: 3rem; color: var(--muted); }
.empty-state-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }

.logout-btn {
  background: none; border: 1.5px solid var(--border); color: var(--muted);
  padding: 8px 16px; border-radius: 50px; font-family: 'Nunito', sans-serif;
  font-size: 0.85rem; font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.logout-btn:hover { border-color: var(--error); color: var(--error); }

/* RESPONSIVE */
@media (max-width: 600px) {
  nav { padding: 0.85rem 1.2rem; }
  .nav-links { gap: 0.8rem; }
  .nav-links a { font-size: 0.8rem; }
  .form-row { grid-template-columns: 1fr; }
  .time-slots { grid-template-columns: repeat(3,1fr); }
  .bookings-table th:nth-child(4), .bookings-table td:nth-child(4) { display: none; }
  .bookings-table th:nth-child(5), .bookings-table td:nth-child(5) { display: none; }
}
</style>
</head>
<body>

<!-- ── NAVIGATION ── -->
<nav>
  <a class="nav-logo" href="#" onclick="showPage('booking')">
    <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="18" cy="18" r="18" fill="#e8f7f2"/>
      <path d="M11 18c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7-7-3.13-7-7z" fill="#3a9e7e" opacity="0.3"/>
      <path d="M14 18c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4-4-1.79-4-4z" fill="#3a9e7e"/>
      <path d="M18 10 L19.5 14 L23.5 14 L20.5 16.5 L21.5 20.5 L18 18 L14.5 20.5 L15.5 16.5 L12.5 14 L16.5 14 Z" fill="white" opacity="0.9"/>
    </svg>
    <span>Sparkle <em>MK</em></span>
  </a>
  <div class="nav-links">
    <a href="#" id="nav-book" class="active" onclick="showPage('booking'); updateNav('nav-book')">Book Online</a>
    <button class="nav-admin-btn" onclick="showPage('admin'); updateNav(null)">Admin ↗</button>
  </div>
</nav>

<!-- ══════════════════════════════════════════
     BOOKING PAGE
══════════════════════════════════════════ -->
<div id="page-booking" class="page active">

  <div class="booking-hero">
    <h1>Book your <span>sparkle</span></h1>
    <p>Choose your service, pick a time, and we'll do the rest. Secure payment online.</p>
  </div>

  <div class="booking-wrapper">

    <!-- STEP INDICATOR -->
    <div class="step-indicator" id="step-indicator">
      <div class="step active" id="step-dot-1">
        <div class="step-circle">1</div>
        <div class="step-label">Service</div>
      </div>
      <div class="step-line" id="line-1"></div>
      <div class="step" id="step-dot-2">
        <div class="step-circle">2</div>
        <div class="step-label">Details</div>
      </div>
      <div class="step-line" id="line-2"></div>
      <div class="step" id="step-dot-3">
        <div class="step-circle">3</div>
        <div class="step-label">Payment</div>
      </div>
    </div>

    <!-- ── STEP 1: SERVICE SELECTION ── -->
    <div class="form-card active" id="card-1">
      <h2>What do you need cleaned?</h2>

      <div class="service-grid">
        <div class="service-option">
          <input type="radio" name="service" id="svc-domestic" value="Domestic Cleaning" data-price="60" data-unit="/visit">
          <label for="svc-domestic">
            <span class="svc-icon">🏠</span>
            <span class="svc-name">Domestic Cleaning</span>
            <span class="svc-price">From £60/visit</span>
            <span class="svc-desc">Regular home clean</span>
            <span class="service-check"></span>
          </label>
        </div>
        <div class="service-option">
          <input type="radio" name="service" id="svc-office" value="Office Cleaning" data-price="80" data-unit="/visit">
          <label for="svc-office">
            <span class="svc-icon">🏢</span>
            <span class="svc-name">Office Cleaning</span>
            <span class="svc-price">From £80/visit</span>
            <span class="svc-desc">Workspace clean</span>
            <span class="service-check"></span>
          </label>
        </div>
        <div class="service-option">
          <input type="radio" name="service" id="svc-deep" value="Deep Cleaning" data-price="150" data-unit=" flat">
          <label for="svc-deep">
            <span class="svc-icon">✨</span>
            <span class="svc-name">Deep Cleaning</span>
            <span class="svc-price">From £150</span>
            <span class="svc-desc">Top-to-bottom refresh</span>
            <span class="service-check"></span>
          </label>
        </div>
      </div>

      <div id="freq-section" style="display:none; margin-bottom:1.5rem;">
        <div class="form-group" style="margin-bottom:0.75rem;">
          <label>Frequency</label>
        </div>
        <div class="freq-grid">
          <div class="freq-option">
            <input type="radio" name="frequency" id="freq-weekly" value="Weekly" data-discount="15">
            <label for="freq-weekly">Weekly <span class="freq-discount">Save 15%</span></label>
          </div>
          <div class="freq-option">
            <input type="radio" name="frequency" id="freq-fort" value="Fortnightly" data-discount="10">
            <label for="freq-fort">Fortnightly <span class="freq-discount">Save 10%</span></label>
          </div>
          <div class="freq-option">
            <input type="radio" name="frequency" id="freq-one" value="One-off" data-discount="0" checked>
            <label for="freq-one">One-off <span class="freq-discount">&nbsp;</span></label>
          </div>
        </div>
      </div>

      <div id="size-section" style="display:none; margin-bottom:1.5rem;">
        <div class="form-group">
          <label>Property size</label>
          <select id="property-size">
            <option value="" disabled selected>Select size…</option>
            <option value="Studio / 1 bed" data-add="0">Studio / 1 bed (+£0)</option>
            <option value="2 bed" data-add="20">2 bed (+£20)</option>
            <option value="3 bed" data-add="35">3 bed (+£35)</option>
            <option value="4+ bed" data-add="55">4+ bed (+£55)</option>
