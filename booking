      <div id="price-preview" style="display:none; margin-bottom:1.5rem; padding:1rem 1.25rem; background:var(--green-light); border-radius:12px; display:flex; justify-content:space-between; align-items:center;">
        <span style="color:var(--muted); font-size:0.9rem;">Estimated price</span>
