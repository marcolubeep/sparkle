      <div id="step1-error" class="login-error" style="text-align:left;">Please select a service to continue.</div>
      <button class="btn-primary" onclick="goStep(2)">Continue →</button>
    </div>

    <!-- ── STEP 2: DATE / ADDRESS / DETAILS ── -->
    <div class="form-card" id="card-2">
      <button class="btn-back" onclick="goStep(1)">← Back</button>
      <h2>Your details & preferred time</h2>

      <div class="form-row">
        <div class="form-group" id="fg-fname">
          <label>First name</label>
