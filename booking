          <span class="field-error">Required</span>
        </div>
        <div class="form-group" id="fg-lname">
          <label>Last name</label>
          <input type="text" id="lname" placeholder="Smith">
          <span class="field-error">Required</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group" id="fg-email">
          <label>Email</label>
          <input type="email" id="email" placeholder="jane@example.com">
          <span class="field-error">Valid email required</span>
        </div>
        <div class="form-group" id="fg-phone">
          <label>Phone</label>
          <input type="tel" id="phone" placeholder="07700 900 000">
          <span class="field-error">Required</span>
        </div>
      </div>
      <div class="form-row full">
        <div class="form-group" id="fg-address">
          <label>Address</label>
          <input type="text" id="address" placeholder="12 Any Street, Milton Keynes">
          <span class="field-error">Required</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group" id="fg-postcode">
          <label>Postcode</label>
          <input type="text" id="postcode" placeholder="MK1 1AA">
          <span class="field-error">Required</span>
        </div>
        <div class="form-group" id="fg-date">
          <label>Preferred date</label>
          <input type="date" id="pref-date">
          <span class="field-error">Please select a date</span>
        </div>
      </div>

      <div class="form-group" style="margin-bottom:1rem;">
        <label>Preferred start time</label>
        <div class="time-slots">
          <div class="time-slot"><input type="radio" name="time" id="t1" value="8:00 AM"><label for="t1">8:00 AM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t2" value="9:00 AM"><label for="t2">9:00 AM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t3" value="10:00 AM"><label for="t3">10:00 AM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t4" value="11:00 AM"><label for="t4">11:00 AM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t5" value="12:00 PM"><label for="t5">12:00 PM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t6" value="1:00 PM"><label for="t6">1:00 PM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t7" value="2:00 PM"><label for="t7">2:00 PM</label></div>
          <div class="time-slot"><input type="radio" name="time" id="t8" value="3:00 PM"><label for="t8">3:00 PM</label></div>
        </div>
      </div>
      <div id="time-error" class="login-error" style="text-align:left; display:none;">Please select a time slot.</div>

      <div class="form-row full" style="margin-top:0.5rem;">
        <div class="form-group">
          <label>Additional notes (optional)</label>
          <textarea id="notes" placeholder="Access instructions, pets, specific areas to focus on…"></textarea>
        </div>
      </div>

      <button class="btn-primary" onclick="goStep(3)" style="margin-top:0.5rem;">Continue →</button>
    </div>

    <!-- ── STEP 3: PAYMENT ── -->
    <div class="form-card" id="card-3">
      <button class="btn-back" onclick="goStep(2)">← Back</button>
      <h2>Review & pay</h2>

      <div class="summary-box" id="booking-summary"></div>

      <div class="payment-area">
        <div class="payment-title">
          Payment details
          <span class="stripe-badge">🔒 Powered by Stripe</span>
        </div>
        <div class="card-field-mock">
          <input type="text" id="card-num" placeholder="Card number" maxlength="19" oninput="formatCard(this)">
          <span style="font-size:16px; color:var(--muted);">💳</span>
        </div>
        <div class="card-row">
          <div class="card-field-mock">
            <input type="text" id="card-exp" placeholder="MM / YY" maxlength="7" oninput="formatExpiry(this)">
          </div>
          <div class="card-field-mock">
            <input type="text" id="card-cvc" placeholder="CVC" maxlength="4" oninput="this.value=this.value.replace(/\D/g,'')">
          </div>
        </div>
        <div class="card-field-mock">
          <input type="text" id="card-name" placeholder="Name on card">
        </div>
        <div class="secure-note">🔐 <strong>256-bit SSL encrypted.</strong> Your card details are never stored on our servers.</div>
      </div>

      <div id="pay-error" class="login-error" style="text-align:left;">Please complete all card details.</div>
      <button class="btn-primary" id="pay-btn" onclick="submitBooking()">Pay & Confirm Booking</button>
      <div style="text-align:center; margin-top:0.75rem; font-size:0.8rem; color:var(--muted);">
        By booking you agree to our cancellation policy. 24h notice required for a full refund.
      </div>
    </div>

    <!-- ── SUCCESS STATE ── -->
    <div class="form-card" id="card-success">
      <div class="success-card">
        <div class="success-icon">✨</div>
        <h2>You're all booked!</h2>
        <p>We'll send a confirmation email shortly. Our team is excited to make your space sparkle.</p>
        <div class="booking-ref" id="booking-ref-display"></div>
        <p style="margin-top:0.5rem; font-size:0.85rem;">Save your reference number in case you need to make changes.</p>
        <button class="btn-secondary" style="width:auto; padding:12px 30px; margin-top:1.5rem;" onclick="resetBooking()">Book another clean</button>
      </div>
    </div>

  </div><!-- /booking-wrapper -->
</div><!-- /page-booking -->


<!-- ══════════════════════════════════════════
     ADMIN PAGE
══════════════════════════════════════════ -->
<div id="page-admin" class="page">

  <!-- LOGIN SCREEN -->
  <div id="admin-login" class="admin-login-wrapper">
    <div class="admin-login-card">
      <h2>Admin Login</h2>
      <p>Sparkle MK management portal</p>
      <div id="login-error" class="login-error">Incorrect password. Please try again.</div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label>Password</label>
        <input type="password" id="admin-pw" placeholder="Enter admin password" onkeydown="if(event.key==='Enter') doLogin()">
      </div>
      <button class="btn-primary" onclick="doLogin()">Sign in</button>
      <div style="margin-top:1.25rem; font-size:12px; color:var(--muted);">Demo password: <strong>sparkle2025</strong></div>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div id="admin-dashboard" class="admin-dashboard" style="display:none;">
    <div class="admin-header">
      <h1>Bookings Dashboard</h1>
      <div class="admin-header-right">
        <select id="admin-sort" onchange="renderBookings()" style="border:1.5px solid var(--border); border-radius:8px; padding:7px 12px; font-family:'Nunito',sans-serif; font-size:0.85rem; color:var(--text); background:white; outline:none; cursor:pointer;">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="date">By appointment</option>
        </select>
        <button class="logout-btn" onclick="doLogout()">Sign out</button>
      </div>
    </div>

    <div class="stats-grid" id="stats-grid"></div>

    <div class="filter-bar" id="filter-bar">
      <button class="filter-btn active" data-filter="all" onclick="setFilter('all')">All</button>
      <button class="filter-btn" data-filter="pending" onclick="setFilter('pending')">Pending</button>
      <button class="filter-btn" data-filter="confirmed" onclick="setFilter('confirmed')">Confirmed</button>
      <button class="filter-btn" data-filter="paid" onclick="setFilter('paid')">Paid</button>
      <button class="filter-btn" data-filter="cancelled" onclick="setFilter('cancelled')">Cancelled</button>
    </div>

    <div class="bookings-table-wrap">
      <table class="bookings-table">
        <thead>
          <tr>
            <th>Ref</th>
            <th>Customer</th>
            <th>Service</th>
            <th>Date & Time</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="bookings-body"></tbody>
      </table>
    </div>
  </div>

</div><!-- /page-admin -->

<script>
/* ════════════════════════════════════
   STATE & STORAGE
════════════════════════════════════ */
const ADMIN_PW = 'sparkle2025';
let currentStep = 1;
let adminFilter = 'all';
let bookingData = {};

function getBookings() {
  try { return JSON.parse(localStorage.getItem('smk_bookings') || '[]'); } catch { return []; }
}
function saveBookings(arr) { localStorage.setItem('smk_bookings', JSON.stringify(arr)); }

/* ════════════════════════════════════
   NAV
════════════════════════════════════ */
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  if (name === 'admin' && !sessionStorage.getItem('smk_auth')) {
    document.getElementById('admin-login').style.display = '';
    document.getElementById('admin-dashboard').style.display = 'none';
  } else if (name === 'admin') {
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-dashboard').style.display = '';
    renderStats(); renderBookings();
  }
  window.scrollTo(0,0);
}
function updateNav(activeId) {
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  if (activeId) document.getElementById(activeId)?.classList.add('active');
}

/* ════════════════════════════════════
   BOOKING STEPS
════════════════════════════════════ */
function goStep(n) {
  if (n === 2 && !validateStep1()) return;
  if (n === 3 && !validateStep2()) return;
  if (n === 3) buildSummary();

  [1,2,3].forEach(i => {
    document.getElementById('card-' + i).classList.remove('active');
    const dot = document.getElementById('step-dot-' + i);
    dot.classList.remove('active','done');
    if (i < n) dot.classList.add('done');
    if (i === n) dot.classList.add('active');
    if (i < 3) {
      const line = document.getElementById('line-' + i);
      line.classList.toggle('done', i < n);
    }
  });
  document.getElementById('card-' + n).classList.add('active');
  currentStep = n;
  window.scrollTo(0, document.getElementById('step-indicator').offsetTop - 100);
}

/* ── Step 1 logic ── */
const radios = () => document.querySelectorAll('input[name="service"]');
radios().forEach(r => r.addEventListener('change', onServiceChange));
document.querySelectorAll('input[name="frequency"]').forEach(r => r.addEventListener('change', updatePrice));
document.getElementById('property-size').addEventListener('change', updatePrice);

function onServiceChange() {
  const v = document.querySelector('input[name="service"]:checked')?.value;
  const isDeep = v === 'Deep Cleaning';
  document.getElementById('freq-section').style.display = isDeep ? 'none' : 'block';
  document.getElementById('size-section').style.display = 'block';
  document.getElementById('price-preview').style.display = 'flex';
  document.getElementById('step1-error').style.display = 'none';
  updatePrice();
}

function updatePrice() {
  const svc = document.querySelector('input[name="service"]:checked');
  const sizeEl = document.getElementById('property-size');
  const freqEl = document.querySelector('input[name="frequency"]:checked');
  if (!svc) return;
  let base = parseFloat(svc.dataset.price || 0);
  const sizeOpt = sizeEl.options[sizeEl.selectedIndex];
  const sizeAdd = parseFloat(sizeOpt?.dataset.add || 0);
  const discount = freqEl ? parseFloat(freqEl.dataset.discount || 0) : 0;
  let total = (base + sizeAdd) * (1 - discount/100);
  document.getElementById('price-preview-value').textContent = '£' + Math.round(total);
}

function validateStep1() {
  const svc = document.querySelector('input[name="service"]:checked');
  if (!svc) { document.getElementById('step1-error').style.display = 'block'; return false; }
  const sizeEl = document.getElementById('property-size');
  if (sizeEl.style.display !== 'none' && !sizeEl.value) {
    alert('Please select a property size.'); return false;
  }
  return true;
}

/* Set min date for date picker */
const dateInput = document.getElementById('pref-date');
const tomorrow = new Date(); tomorrow.setDate(tomorrow.getDate()+1);
dateInput.min = tomorrow.toISOString().split('T')[0];

function validateStep2() {
  let ok = true;
  const fields = [
    ['fg-fname','fname', v => v.trim().length > 0],
    ['fg-lname','lname', v => v.trim().length > 0],
    ['fg-email','email', v => /^[^@]+@[^@]+\.[^@]+$/.test(v)],
    ['fg-phone','phone', v => v.trim().length > 5],
    ['fg-address','address', v => v.trim().length > 3],
    ['fg-postcode','postcode', v => v.trim().length > 2],
    ['fg-date','pref-date', v => !!v],
  ];
  fields.forEach(([gid, fid, fn]) => {
    const el = document.getElementById(fid);
    const grp = document.getElementById(gid);
    if (!fn(el.value)) { grp.classList.add('error'); ok = false; }
    else grp.classList.remove('error');
  });
  const time = document.querySelector('input[name="time"]:checked');
  const timeErr = document.getElementById('time-error');
  if (!time) { timeErr.style.display = 'block'; ok = false; } else timeErr.style.display = 'none';
  return ok;
}

/* ── Summary ── */
function buildSummary() {
  const svc = document.querySelector('input[name="service"]:checked');
  const freq = document.querySelector('input[name="frequency"]:checked');
  const sizeEl = document.getElementById('property-size');
  const sizeOpt = sizeEl.options[sizeEl.selectedIndex];
  const time = document.querySelector('input[name="time"]:checked');

  let base = parseFloat(svc.dataset.price);
  const sizeAdd = parseFloat(sizeOpt?.dataset.add || 0);
  const discount = freq ? parseFloat(freq.dataset.discount || 0) : 0;
  const subtotal = base + sizeAdd;
  const discountAmt = Math.round(subtotal * discount / 100);
  const total = subtotal - discountAmt;

  bookingData = {
    service: svc.value,
    frequency: freq ? freq.value : 'One-off',
    size: sizeEl.value || '—',
    name: document.getElementById('fname').value + ' ' + document.getElementById('lname').value,
    email: document.getElementById('email').value,
    phone: document.getElementById('phone').value,
    address: document.getElementById('address').value + ', ' + document.getElementById('postcode').value,
    date: document.getElementById('pref-date').value,
    time: time?.value,
    notes: document.getElementById('notes').value,
    total: total,
    subtotal: subtotal,
    discount: discountAmt,
    discountPct: discount,
  };

  const dateStr = new Date(bookingData.date).toLocaleDateString('en-GB', {weekday:'long', day:'numeric', month:'long', year:'numeric'});

  document.getElementById('booking-summary').innerHTML = `
    <div class="summary-row"><span class="summary-label">Service</span><span class="summary-value">${bookingData.service}</span></div>
    <div class="summary-row"><span class="summary-label">Frequency</span><span class="summary-value">${bookingData.frequency}</span></div>
    <div class="summary-row"><span class="summary-label">Property size</span><span class="summary-value">${bookingData.size}</span></div>
    <div class="summary-row"><span class="summary-label">Date</span><span class="summary-value">${dateStr}</span></div>
    <div class="summary-row"><span class="summary-label">Time</span><span class="summary-value">${bookingData.time}</span></div>
    <div class="summary-row"><span class="summary-label">Address</span><span class="summary-value">${bookingData.address}</span></div>
    ${discountAmt > 0 ? `<div class="summary-row"><span class="summary-label">Discount (${discount}%)</span><span class="summary-value" style="color:var(--green-dark)">−£${discountAmt}</span></div>` : ''}
    <div class="summary-row total"><span>Total</span><span>£${total}</span></div>
  `;
  document.getElementById('pay-btn').textContent = `Pay £${total} & Confirm Booking`;
}

/* ── Payment formatting ── */
function formatCard(el) {
  el.value = el.value.replace(/\D/g,'').slice(0,16).replace(/(.{4})/g,'$1 ').trim();
}
function formatExpiry(el) {
  let v = el.value.replace(/\D/g,'');
  if (v.length >= 2) v = v.slice(0,2) + ' / ' + v.slice(2,4);
  el.value = v;
}

function submitBooking() {
  const num = document.getElementById('card-num').value.replace(/\s/g,'');
  const exp = document.getElementById('card-exp').value;
  const cvc = document.getElementById('card-cvc').value;
  const name = document.getElementById('card-name').value;
  const errEl = document.getElementById('pay-error');

  if (num.length < 15 || exp.length < 7 || cvc.length < 3 || !name.trim()) {
    errEl.style.display = 'block'; return;
  }
  errEl.style.display = 'none';

  const btn = document.getElementById('pay-btn');
  btn.disabled = true; btn.textContent = 'Processing…';

  setTimeout(() => {
    const ref = 'SMK-' + Math.random().toString(36).substr(2,6).toUpperCase();
    const booking = {
      ref, ...bookingData,
      status: 'paid',
      createdAt: new Date().toISOString(),
      fname: document.getElementById('fname').value,
      lname: document.getElementById('lname').value,
    };
    const bookings = getBookings();
    bookings.unshift(booking);
    saveBookings(bookings);

    // show success
    [1,2,3].forEach(i => document.getElementById('card-' + i).classList.remove('active'));
    document.getElementById('step-indicator').style.display = 'none';
    document.getElementById('card-success').classList.add('active');
    document.getElementById('booking-ref-display').textContent = ref;
    btn.disabled = false;
  }, 1800);
}

function resetBooking() {
  document.querySelectorAll('input[type="radio"]').forEach(r => r.checked = false);
  document.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"], input[type="date"], textarea, select').forEach(el => el.value = '');
  document.getElementById('freq-section').style.display = 'none';
  document.getElementById('size-section').style.display = 'none';
  document.getElementById('price-preview').style.display = 'none';
  document.getElementById('step-indicator').style.display = 'flex';
  document.getElementById('card-success').classList.remove('active');
  document.getElementById('pay-btn').textContent = 'Pay & Confirm Booking';
  goStep(1);
}

/* ════════════════════════════════════
   ADMIN AUTH
════════════════════════════════════ */
function doLogin() {
  const pw = document.getElementById('admin-pw').value;
  const errEl = document.getElementById('login-error');
  if (pw === ADMIN_PW) {
    sessionStorage.setItem('smk_auth','1');
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-dashboard').style.display = '';
    renderStats(); renderBookings();
    errEl.style.display = 'none';
  } else {
    errEl.style.display = 'block';
    document.getElementById('admin-pw').value = '';
  }
}
function doLogout() {
  sessionStorage.removeItem('smk_auth');
  document.getElementById('admin-dashboard').style.display = 'none';
  document.getElementById('admin-login').style.display = '';
  document.getElementById('admin-pw').value = '';
}

/* ════════════════════════════════════
   ADMIN DASHBOARD
════════════════════════════════════ */
function setFilter(f) {
  adminFilter = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.filter === f));
  renderBookings();
}

function renderStats() {
  const all = getBookings();
  const pending = all.filter(b => b.status === 'pending').length;
  const confirmed = all.filter(b => b.status === 'confirmed').length;
  const paid = all.filter(b => b.status === 'paid').length;
  const revenue = all.filter(b => b.status === 'paid').reduce((s,b) => s + (b.total||0), 0);
  document.getElementById('stats-grid').innerHTML = `
    <div class="stat-card"><div class="stat-num">${all.length}</div><div class="stat-label">Total bookings</div></div>
    <div class="stat-card"><div class="stat-num">${pending}</div><div class="stat-label">Pending</div></div>
    <div class="stat-card"><div class="stat-num">${confirmed}</div><div class="stat-label">Confirmed</div></div>
    <div class="stat-card"><div class="stat-num">£${revenue}</div><div class="stat-label">Revenue (paid)</div></div>
  `;
}

function renderBookings() {
  let data = getBookings();
  const sort = document.getElementById('admin-sort')?.value || 'newest';

  if (sort === 'oldest') data = [...data].reverse();
  else if (sort === 'date') data = [...data].sort((a,b) => new Date(a.date) - new Date(b.date));

  if (adminFilter !== 'all') data = data.filter(b => b.status === adminFilter);

  const tbody = document.getElementById('bookings-body');
  if (!data.length) {
    tbody.innerHTML = `<tr><td colspan="7"><div class="empty-state"><div class="empty-state-icon">📋</div><div>No bookings found</div></div></td></tr>`;
    return;
  }
  tbody.innerHTML = data.map(b => {
    const dateStr = b.date ? new Date(b.date).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'numeric'}) : '—';
    const badge = {
      pending: '<span class="badge badge-pending">Pending</span>',
      confirmed: '<span class="badge badge-confirmed">Confirmed</span>',
      paid: '<span class="badge badge-paid">Paid</span>',
      cancelled: '<span class="badge badge-cancelled">Cancelled</span>',
    }[b.status] || '';

    let actions = '';
    if (b.status === 'pending') actions = `<button class="action-btn confirm" onclick="updateStatus('${b.ref}','confirmed')">Confirm</button><button class="action-btn cancel" onclick="updateStatus('${b.ref}','cancelled')">Cancel</button>`;
    else if (b.status === 'confirmed') actions = `<button class="action-btn paid" onclick="updateStatus('${b.ref}','paid')">Mark paid</button><button class="action-btn cancel" onclick="updateStatus('${b.ref}','cancelled')">Cancel</button>`;
    else if (b.status === 'paid') actions = `<button class="action-btn cancel" onclick="updateStatus('${b.ref}','cancelled')">Refund</button>`;
    else actions = '<span style="color:var(--muted);font-size:12px;">—</span>';

    return `<tr>
      <td style="font-weight:700; font-size:12px; color:var(--green-dark);">${b.ref}</td>
      <td><div style="font-weight:700;">${b.name}</div><div style="font-size:12px;color:var(--muted);">${b.email}</div></td>
      <td><div>${b.service}</div><div style="font-size:12px;color:var(--muted);">${b.frequency||''}</div></td>
      <td>${dateStr}<br><span style="font-size:12px;color:var(--muted);">${b.time||''}</span></td>
      <td style="font-weight:700;">£${b.total||'—'}</td>
      <td>${badge}</td>
      <td><div class="action-btns">${actions}</div></td>
    </tr>`;
  }).join('');
}

function updateStatus(ref, status) {
  const bookings = getBookings();
  const idx = bookings.findIndex(b => b.ref === ref);
  if (idx > -1) { bookings[idx].status = status; saveBookings(bookings); }
  renderStats(); renderBookings();
}

